Options -MultiViews
RewriteEngine On
RewriteBase /

# ── Legacy WordPress / Elementor SEO (301) ──
RewriteRule ^web-development/?$ /services/website-as-a-service [R=301,L]
RewriteRule ^elementor-193/?$ /resources/best-client-portal-small-accounting-firms [R=301,L]
RewriteRule ^elementor-504/?$ /resources/accounting-firm-website-design-guide [R=301,L]
RewriteRule ^elementor-[0-9]+.*$ /resources [R=301,L]
RewriteRule ^resources/how-to-reduce-admin-in-accounting-firm/?$ /resources/how-to-reduce-admin-accounting-firm [R=301,L]
RewriteRule ^resources/pinnacle-tax-near-story/?$ /resources/pinnacle-tax-case-study [R=301,L]
RewriteRule ^resources/chen-associates-case-study/?$ /resources/abc-inc-chartered-accountants-website-case-study [R=301,L]
RewriteRule ^resources/top-6-compliance-accounting-websites/?$ /resources/popia-compliance-accounting-websites [R=301,L]
RewriteRule ^resources/four-rebuild-requirements/?$ /resources/fsca-website-requirements [R=301,L]
RewriteCond %{QUERY_STRING} (^|&)page_id= [NC]
RewriteRule ^$ /? [R=301,L]

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com https://www.googletagmanager.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
</IfModule>

# Serve existing files and directories directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route all other requests to index.html (Vue Router handles them)
RewriteRule ^ index.html [L]
